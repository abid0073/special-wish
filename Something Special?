<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Birthday Magic ❤️</title>
    <style>
        body {
            margin: 0;
            background-color: #000;
            color: white;
            font-family: 'Comic Sans MS', sans-serif;
            overflow: hidden;
            display: flex;
            align-items: center;
            height: 100vh;
            width: 150vw;
        }

        #text-container {
            position: absolute;
            left: 5%;
            top: 50%;
            transform: translateY(-50%);
            width: 55%;
            opacity: 0;
            transition: opacity 2s ease;
            z-index: 10;
        }

        .line {
            font-size: 1.3rem;
            margin-bottom: 12px;
            display: block;
            line-height: 1.4;
            color: #fff;
            font-weight: bold;
        }

        #canvas-container {
            position: absolute;
            left: 50%;
            transform: translateX(-55%);
            bottom: 16%;
            width: 600px;
            height: 600px;
            transition: all 2.5s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex;
            align-items: flex-end;
            justify-content: center;
        }

        canvas {
            width: 100%;
            height: 100%;
        }

        @media (max-width: 768px) {
            #canvas-container { width: 320px; height: 450px; }
            .line { font-size: 1.1rem; }
        }
    </style>
</head>
<body>

    <div id="text-container"></div>
    
    <div id="canvas-container">
        <canvas id="treeCanvas"></canvas>
    </div>

    <script>
        const canvas = document.getElementById('treeCanvas');
        const ctx = canvas.getContext('2d');
        canvas.width = 500;
        canvas.height = 600;

        const messages = [
            "Hey you 💕",
            "Happy Birthday 🎂",
            "May ALLAH bless you 🎈",
            "And give you many happiness ❤️",
            "Just saying... you're pretty awesome 😊",
            "Sending good vibes and maybe a wink 😉",
            "Hope u have a great day today & for the lifetime 💕"
             ];

        function drawHeart(x, y, size, color) {
            ctx.fillStyle = color;
            ctx.beginPath();
            ctx.moveTo(x, y);
            ctx.bezierCurveTo(x, y - size/2, x - size, y - size/2, x - size, y);
            ctx.bezierCurveTo(x - size, y + size/1.5, x, y + size * 1.5, x, y + size * 1.5);
            ctx.bezierCurveTo(x, y + size * 1.5, x + size, y + size/1.5, x + size, y);
            ctx.bezierCurveTo(x + size, y - size/2, x, y - size/2, x, y);
            ctx.fill();
        }

        let heartCount = 0;
        const colors = ['#ff4d6d', '#ff758f', '#ffb3c1', '#ff0054', '#c9184a', '#ff8fab'];

        function animateTree() {
            // কাণ্ড
            ctx.fillStyle = '#ffb3c1';
            ctx.fillRect(245, 450, 12, 150);

            function addHearts() {
                if (heartCount < 2121) { 
                    let t = Math.random() * Math.PI * 2;
                    let r = Math.pow(Math.random(), 0.6) * 160;
                    
                    let x = 250 + 16 * Math.pow(Math.sin(t), 3) * (r/10);
                    let y = 250 - (13 * Math.cos(t) - 5 * Math.cos(2*t) - 2 * Math.cos(3*t) - Math.cos(4*t)) * (r/10);
                    
                    
                    let size = Math.random() * 6 + 8; 
                    drawHeart(x, y, size, colors[Math.floor(Math.random() * colors.length)]);
                    
                    heartCount++;
                    
                    if (heartCount % 2 === 0) {
                        requestAnimationFrame(addHearts);
                    } else {
                        addHearts();
                    }
                }
            }
            addHearts();
        }

        function typeWriter() {
            let lineIndex = 0;
            const container = document.getElementById('text-container');
            container.style.opacity = "1";

            function type() {
                if (lineIndex < messages.length) {
                    let div = document.createElement('div');
                    div.className = 'line';
                    container.appendChild(div);
                    let charIndex = 0;
                    let str = messages[lineIndex];
                    
                    let timer = setInterval(() => {
                        div.innerHTML += str[charIndex];
                        charIndex++;
                        if (charIndex === str.length) {
                            clearInterval(timer);
                            lineIndex++;
                            setTimeout(type, 500);
                        }
                    }, 50);
                }
            }
            type();
        }

        
        animateTree(); 

        setTimeout(() => {
            
            document.getElementById('canvas-container').style.left = "75%";
            setTimeout(typeWriter, 1200); 
        }, 3500);

    </script>
</body>
</html>
